# AssemblyAI API key for real-time transcription
ASSEMBLYAI_API_KEY=your-assemblyai-api-key-here

# Optional: AssemblyAI streaming settings (v3)
ASSEMBLYAI_SAMPLE_RATE=16000
ASSEMBLYAI_SPEECH_MODEL=u3-rt-pro
ASSEMBLYAI_ENCODING=pcm_s16le

# n8n webhook endpoint for final transcript delivery
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/transcript
