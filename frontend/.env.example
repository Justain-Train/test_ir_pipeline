# Real-Time Transcription Service Configuration
# ================================================

# Backend WebSocket URL for real-time transcription
# Default: ws://localhost:8000/ws/session (local development)
# Production: Use your deployed backend URL with wss:// for secure connections
VITE_BACKEND_URL=ws://localhost:8000/ws/session

# Optional: Backend HTTP base URL (for REST API calls if needed)
# VITE_BACKEND_HTTP_URL=http://localhost:8000

# Optional: Environment identifier
# VITE_ENVIRONMENT=development

# n8n webhook URL for offline audio file uploads
# This endpoint receives audio files via multipart/form-data for transcription
VITE_N8N_UPLOAD_WEBHOOK_URL=https://your-n8n-instance.com/webhook/upload-audio

# n8n webhook URL for AI summary generation (RAG + Groq)
# This endpoint receives { transcript } and returns a summary
VITE_N8N_SUMMARY_WEBHOOK_URL=https://your-n8n-instance.com/webhook/summary

# n8n webhook URL for doctor follow-up Q&A
# This endpoint receives { question, scope, k, transcript_id } and returns { answer_text, supporting_turns, safety_note }
# Falls back to VITE_N8N_SUMMARY_WEBHOOK_URL if not set
